(
    features: "MAPPABLE_PRIMARY_BUFFERS | CLEAR_TEXTURE",
    expectations: [
        (
            name: "Quad",
            buffer: PointerId(0x10),
            offset: 0,
            data: File("clear-texture.bin", 16384),
        ),
        (
            name: "buffer clear",
            buffer: PointerId(0x110),
            offset: 0,
            data: Raw([
                0x00, 0x00, 0x80, 0xBF,
                0x00, 0x00, 0x00, 0x00,
                0x00, 0x00, 0x00, 0x00,
                0x00, 0x00, 0x80, 0x3F,
            ]),
        )
    ],
    actions: [
        CreateTexture(PointerId(0x10), (
            label: Some("Output Texture"),
            size: (
                width: 64,
                height: 64,
            ),
            mip_level_count: 1,
            sample_count: 1,
            dimension: r#2d,
            format: "rgba8unorm",
            usage: "COPY_SRC | COPY_DST | STORAGE_BINDING | RENDER_ATTACHMENT",
            view_formats: [],
        )),
        // First fill the texture to ensure it wasn't just zero initialized or "happened" to be zero.
        WriteTexture(
            to: (
                texture: PointerId(0x10),
                mip_level: 0,
                array_layer: 0,
            ),
            data: File("quad.bin"),
            layout: (
                offset: 0,
                bytes_per_row: Some(256),
                rows_per_image: None,
            ),
            size: (
                width: 64,
                height: 64,
            ),
        ),
        CreateBuffer(
            PointerId(0x10),
            (
                label: Some("Output Buffer"),
                size: 16384,
                usage: "MAP_READ | COPY_DST",
                mapped_at_creation: false,
            ),
        ),

        CreateBuffer(
            PointerId(0x110),
            (
                label: Some("Buffer to be cleared"),
                size: 16,
                usage: "MAP_READ | COPY_DST | VERTEX",
                mapped_at_creation: false,
            ),
        ),
        // Make sure there is something in the buffer, otherwise it might be just zero init!
        WriteBuffer(
            id: PointerId(0x110),
            data: File("data1.bin"),
            offset: 0,
            size: 16,
            queued: true,
        ),
        Submit(1, [
            ClearTexture(
                dst: PointerId(0x10),
                subresource_range: ImageSubresourceRange(
                    aspect: all,
                    baseMipLevel: 0,
                    mipLevelCount: None,
                    baseArrayLayer: 0,
                    arrayLayerCount: None,
                ),
            ),
            CopyTextureToBuffer(
                src: (
                    texture: PointerId(0x10),
                    mip_level: 0,
                    array_layer: 0,
                ),
                dst:  (
                    buffer: PointerId(0x10),
                    layout: (
                        offset: 0,
                        bytes_per_row: Some(256),
                        rows_per_image: None,
                    ),
                ),
                size: (
                    width: 64,
                    height: 64,
                ),
            ),
            // Partial clear to prove
            ClearBuffer(
                dst: PointerId(0x110),
                offset: 4,
                size: Some(8),
            )
        ]),
    ],
)
