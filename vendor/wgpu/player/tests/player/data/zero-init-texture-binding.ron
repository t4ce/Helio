(
    features: "",
    expectations: [
        (
            name: "Sampled Texture",
            buffer: PointerId(0x10),
            offset: 0,
            data: File("zero-16k.bin", 16384),
        ),
        (
            name: "Storage Texture",
            buffer: PointerId(0x110),
            offset: 0,
            data: File("zero-16k.bin", 16384),
        ),
        // MISSING: Texture binding arrays
        // MISSING: Partial views
    ],
    actions: [
        CreateTexture(PointerId(0x10), (
            label: Some("Sampled Texture"),
            size: (
                width: 64,
                height: 64,
            ),
            mip_level_count: 1,
            sample_count: 1,
            dimension: r#2d,
            format: "rgba8unorm",
            usage: "TEXTURE_BINDING | COPY_SRC",
            view_formats: [],
        )),
        CreateTextureView(
            id: PointerId(0x10),
            parent: PointerId(0x10),
            desc: (),
        ),
        CreateBuffer(
            PointerId(0x10),
            (
                label: Some("Sampled Texture Buffer"),
                size: 16384,
                usage: "MAP_READ | COPY_DST",
                mapped_at_creation: false,
            ),
        ),
        CreateTexture(PointerId(0x110), (
            label: Some("Storage Texture"),
            size: (
                width: 64,
                height: 64,
            ),
            mip_level_count: 1,
            sample_count: 1,
            dimension: r#2d,
            format: "rgba8unorm",
            usage: "STORAGE_BINDING | COPY_SRC",
            view_formats: [],
        )),
        CreateTextureView(
            id: PointerId(0x110),
            parent: PointerId(0x110),
            desc: (),
        ),
        CreateBuffer(
            PointerId(0x110),
            (
                label: Some("Storage Texture Buffer"),
                size: 16384,
                usage: "MAP_READ | COPY_DST",
                mapped_at_creation: false,
            ),
        ),


        CreateBindGroupLayout(PointerId(0x10), (
            label: None,
            entries: [
                (
                    binding: 0,
                    visibility: "COMPUTE",
                    ty: Texture (
                        sample_type: Float(filterable: true),
                        view_dimension: r#2d,
                        multisampled: false,
                    ),
                    count: None,
                ),
                (
                    binding: 1,
                    visibility: "COMPUTE",
                    ty: StorageTexture (
                        access: r#write-only,
                        format: "rgba8unorm",
                        view_dimension: r#2d,
                    ),
                    count: None,
                ),
            ],
        )),
        CreateBindGroup(PointerId(0x10), (
            label: None,
            layout: PointerId(0x10),
            entries: [
                (
                    binding: 0,
                    resource: TextureView(PointerId(0x10)),
                ),
                (
                    binding: 1,
                    resource: TextureView(PointerId(0x110)),
                ),
            ],
        )),
        CreatePipelineLayout(PointerId(0x10), (
            label: None,
            bind_group_layouts: [
                Some(PointerId(0x10)),
            ],
            immediate_size: 0,
        )),
        CreateShaderModule(
            id: PointerId(0x10),
            desc: (
                label: None,
                flags: (bits: 3),
            ),
            data: File("zero-init-texture-binding.wgsl"),
        ),
        CreateComputePipeline(
            id: PointerId(0x10),
            desc: (
                label: None,
                layout: Some(PointerId(0x10)),
                stage: (
                    module: PointerId(0x10),
                    entry_point: None,
                    constants: {},
                    zero_initialize_workgroup_memory: true,
                    vertex_pulling_transform: false,
                ),
            ),
        ),

        Submit(1, [
            RunComputePass(
                pass: (
                    commands: [
                        SetPipeline(PointerId(0x10)),
                        SetBindGroup(
                            index: 0,
                            num_dynamic_offsets: 0,
                            bind_group: Some(PointerId(0x10)),
                        ),
                        DispatchWorkgroups((4, 1, 1)),
                    ],
                    dynamic_offsets: [],
                    string_data: [],
                    immediates_data: [],
                ),
            ),
            CopyTextureToBuffer(
                src: (
                    texture: PointerId(0x10),
                    mip_level: 0,
                    array_layer: 0,
                ),
                dst:  (
                    buffer: PointerId(0x10),
                    layout: (
                        offset: 0,
                        bytes_per_row: Some(256),
                        rows_per_image: Some(64),
                    ),
                ),
                size: (
                    width: 64,
                    height: 64,
                ),
            ),
            CopyTextureToBuffer(
                src: (
                    texture: PointerId(0x110),
                    mip_level: 0,
                    array_layer: 0,
                ),
                dst:  (
                    buffer: PointerId(0x110),
                    layout: (
                        offset: 0,
                        bytes_per_row: Some(256),
                        rows_per_image: Some(64),
                    ),
                ),
                size: (
                    width: 64,
                    height: 64,
                ),
            ),
        ]),
    ],
)
