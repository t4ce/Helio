%28 = OpConstantNull  %7
%30 = OpTypePointer StorageBuffer %3
%31 = OpTypeCooperativeMatrixKHR %3 %8 %10 %10 %22
%32 = OpConstant  %9  1
%35 = OpTypeCooperativeMatrixKHR %3 %8 %10 %10 %32
%38 = OpTypePointer StorageBuffer %5
%19 = OpFunction  %2  None %20
%18 = OpLabel
%26 = OpVariable  %27  Function %28
%23 = OpAccessChain  %21  %12 %22
%25 = OpAccessChain  %24  %15 %22
OpBranch %29
%29 = OpLabel
%33 = OpAccessChain  %30  %23 %22
%34 = OpCooperativeMatrixLoadKHR  %31  %33 %32 %10
%36 = OpAccessChain  %30  %23 %22
%37 = OpCooperativeMatrixLoadKHR  %35  %36 %32 %10
%39 = OpAccessChain  %38  %25 %22
%40 = OpCooperativeMatrixLoadKHR  %7  %39 %32 %10
OpStore %26 %40
%41 = OpLoad  %7  %26
