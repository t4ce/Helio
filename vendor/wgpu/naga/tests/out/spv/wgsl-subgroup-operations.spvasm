%52 = OpGroupNonUniformShuffleUp  %3  %26 %16 %19
%53 = OpCompositeExtract  %3  %7 1
%54 = OpISub  %3  %53 %19
%55 = OpGroupNonUniformShuffleXor  %3  %26 %16 %54
%56 = OpGroupNonUniformQuadBroadcast  %3  %26 %16 %21
%57 = OpGroupNonUniformQuadSwap  %3  %26 %16 %20
%58 = OpGroupNonUniformQuadSwap  %3  %26 %16 %19
%59 = OpGroupNonUniformQuadSwap  %3  %26 %16 %60
