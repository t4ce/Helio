%39 = OpGroupNonUniformBitwiseOr  %3  %26 Reduce %16
%40 = OpGroupNonUniformBitwiseXor  %3  %26 Reduce %16
%41 = OpGroupNonUniformIAdd  %3  %26 ExclusiveScan %16
%42 = OpGroupNonUniformIMul  %3  %26 ExclusiveScan %16
