    let l_s_c_vv = s_am[idx][idx];
    let l_s_e_ccc = s_am[0][0][0];
    let l_s_e_ccv = s_am[0][0][idx];
    let l_s_e_cvc = s_am[0][idx][0];
    let l_s_e_cvv = s_am[0][idx][idx];
    let l_s_e_vcc = s_am[idx][0][0];
    let l_s_e_vcv = s_am[idx][0][idx];
